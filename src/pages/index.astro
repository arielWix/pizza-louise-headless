---
import Site from '../layouts/Site.astro';

const origin = Astro.url.origin;

const description =
  'פיצה לואיז — פיצה ניו יורקית אמיתית, כשרה חלבית, שנולדה מאהבה לטעמים של מנהטן וברוקלין. בצק ביגה שתופח 72 שעות, רוטב עגבניות ביתי וגבינת מוצרלה פרימיום. משלוח מהיר או איסוף עצמי.';

const check = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Restaurant',
    name: 'פיצה לואיז',
    description,
    servesCuisine: ['פיצה', 'ניו יורק סטייל', 'איטלקי'],
    priceRange: '₪₪',
    url: origin + '/',
    image: origin + '/assets/hero.jpeg',
    acceptsReservations: false,
    hasMenu: origin + '/menu',
    areaServed: 'ראשון לציון',
    openingHours: ['Su-Th 11:00-23:00', 'Sa 20:00-24:00'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'פיצה לואיז — הסיפור שלנו',
    description,
    url: origin + '/',
  },
];
---
<Site
  title="פיצה לואיז — פיצה ניו יורקית אמיתית"
  description={description}
  canonicalPath="/"
  ogImage="/assets/gallery-bar.jpeg"
  jsonLd={jsonLd}
>
  <section class="about-section">
    <div class="about-eyebrow"><span class="about-kicker" lang="he">קצת עלינו</span></div>
    <h1 class="about-h1">נולדנו מאהבה לפיצה <em>ניו יורקית</em></h1>
    <p class="about-lede">הבאנו לישראל את הטעמים האותנטיים של מנהטן וברוקלין — כשר חלבי, טרי כל יום.</p>

    <div class="about-block">
      <div>
        <p class="about-kicker" lang="en">Fast Delivery</p>
        <h2>הפיצה הטובה ביותר <em>בדרך אליכם!</em></h2>
        <p>אנחנו מבינים שכשרוצים פיצה אמיתית – רוצים אותה מהר! לכן פיתחנו מערכת משלוחים מתקדמת שמבטיחה שהפיצה שלכם תגיע אליכם חמה, טרייה וטעימה בדיוק כמו ברגע שיצאה מהתנור.</p>
        <div class="about-bullets">
          <div class="about-bullet"><Fragment set:html={check} /> משלוח עד הבית (ראשל"צ בלבד)</div>
          <div class="about-bullet"><Fragment set:html={check} /> משלוח תוך 60 דקות</div>
        </div>
      </div>
      <div class="about-features">
        <div class="about-feature"><div class="f-title">בצק טרי יום יום</div><div class="f-desc">נילושה בבוקר ומתפחת במשך 24 שעות למרקם מושלם</div></div>
        <div class="about-feature"><div class="f-title">רוטב עגבניות ביתי</div><div class="f-desc">מבושל לאט עם תבלינים איטלקיים אותנטיים</div></div>
        <div class="about-feature"><div class="f-title">גבינת מוצרלה פרימיום</div><div class="f-desc">טרייה מדי יום עם המסה מושלמת</div></div>
      </div>
    </div>

    <div class="about-block">
      <div>
        <p class="about-kicker" lang="en">Made with Love</p>
        <h2>אנחנו מכינים את הפיצה <em>הטובה ביותר בעיר</em></h2>
        <p>פיצה לואיז נוסדה מתוך אהבה אמיתית לפיצה ניו יורקית ורצון להביא לישראל את הטעמים האותנטיים של מנהטן וברוקלין. כל פיצה מוכנת בקפדנות מקסימלית, מהעיסה שנילושה בבוקר ועד לתוספות הטריות שמגיעות מידי יום.</p>
      </div>
      <img class="about-img" src="/assets/fotter-2.jpg" alt="פיצה לואיז" loading="lazy" data-reveal />
    </div>

    <div class="about-stats">
      <div class="about-stat"><div class="num">12</div><div class="lbl">אנשי צוות לשירותכם</div></div>
      <div class="about-stat"><div class="num">35</div><div class="lbl">הזמנות בשעה</div></div>
      <div class="about-stat"><div class="num">25</div><div class="lbl">סוגי פיצה</div></div>
      <div class="about-stat"><div class="num">15,000</div><div class="lbl">לקוחות מרוצים</div></div>
    </div>
  </section>
</Site>
