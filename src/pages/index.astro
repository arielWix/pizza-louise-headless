---
import Site from '../layouts/Site.astro';
import { getCatalog } from '../lib/catalog.js';
import { money } from '../lib/art.js';

const catalog = await getCatalog();
const origin = Astro.url.origin;

const description =
  'פיצה לואיז — פיצה ניו יורקית אמיתית, כשרה חלבית. בצק ביגה שתופח 72 שעות ותנור אבן לוהט. הרכיבו מגש אונליין עם תוספות לכל רבע — משלוח או איסוף עצמי.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Restaurant',
    name: 'פיצה לואיז',
    description,
    servesCuisine: ['פיצה', 'ניו יורק סטייל', 'איטלקי'],
    priceRange: '₪₪',
    url: origin + '/',
    image: origin + '/assets/hero.jpeg',
    acceptsReservations: false,
    hasMenu: origin + '/#menu',
    areaServed: 'ראשון לציון',
    openingHours: ['Su-Th 11:00-23:00', 'Sa 20:00-24:00'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Menu',
    name: 'תפריט פיצה לואיז',
    hasMenuSection: {
      '@type': 'MenuSection',
      name: 'פיצות',
      hasMenuItem: catalog.pizzas.map((p) => ({
        '@type': 'MenuItem',
        name: p.name,
        description: p.desc,
        url: origin + '/pizza/' + p.slug,
        offers: { '@type': 'Offer', price: p.priceL, priceCurrency: 'ILS' },
      })),
    },
  },
];
---
<Site
  title="פיצה לואיז — פיצה ניו יורקית אמיתית"
  description={description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <p class="hero-badge">פיצה לואיז · כשר חלבי · ניו יורק סטייל</p>
      <h1>פיצה <em>ניו יורקית</em> אמיתית</h1>
      <p>משולשים ענקיים ברוח מנהטן, בצק על בסיס ביגה שתופח 72 שעות, ותנור לוהט שנותן את הקראנץ' המושלם. בחרו מגש — ותרכיבו אותו בדיוק כמו שאתם אוהבים.</p>
    </div>
  </section>

  <section class="menu-section" id="menu">
    <div class="section-head"><h2>התפריט שלנו</h2></div>
    <div class="menu-grid">
      {catalog.pizzas.map((p) => (
        <a class="pizza-card" href={`/pizza/${p.slug}`}>
          <div class="img-wrap">
            {p.image ? (
              <img src={p.image} alt={p.name} loading="lazy" />
            ) : (
              <div class="img-placeholder">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="m21 15-5-5L5 21"></path></svg>
                <span>תמונה: {p.name}</span>
              </div>
            )}
          </div>
          <div class="card-body">
            <div class="card-title-row">
              <h3 class="name">{p.name}</h3>
              <div class="from-price">החל מ־{money(p.priceM)}</div>
            </div>
            <p class="desc">{p.desc}</p>
            <div class="card-cta">
              להרכבת המגש
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:scaleX(-1);"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="gallery">
      <img src="/assets/fotter-1.jpg" alt="קינוחים מהתנור של פיצה לואיז" loading="lazy" />
      <img src="/assets/fotter-2.jpg" alt="מאפה שוקולד" loading="lazy" />
      <img src="/assets/fotter-3.jpg" alt="הבר של פיצה לואיז" loading="lazy" />
    </div>
  </section>
</Site>
