<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>פיצה לואיז — הטעם האמיתי של ניו יורק</title>
<link rel="icon" type="image/png" href="/assets/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;500;700&family=Assistant:wght@400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
  :root { --accent: #D8402F; }
  html, body { margin: 0; padding: 0; background: #14100D; }
  * { box-sizing: border-box; }
  body { min-height: 100vh; overflow-x: clip; background: #14100D; color: #F0E7D8; font-family: 'Assistant', sans-serif; -webkit-font-smoothing: antialiased; }
  a { color: #E8DCC8; text-decoration: none; }
  a:hover { color: #E2703A; }
  ::selection { background: rgba(226,112,58,0.35); }
  @keyframes ecFadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes ecPop { 0% { transform: scale(0.4); opacity: 0; } 70% { transform: scale(1.12); } 100% { transform: scale(1); opacity: 1; } }
  .serif { font-family: 'Frank Ruhl Libre', serif; }

  /* ===== NAV ===== */
  .nav { position: sticky; top: 0; z-index: 50; display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 76px; background: rgba(20,16,13,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(240,231,216,0.08); }
  .nav-start { display: flex; align-items: center; gap: 40px; }
  .nav-brand { display: flex; align-items: center; gap: 14px; cursor: pointer; }
  .nav-brand img { width: 44px; height: 44px; border-radius: 10px; object-fit: cover; }
  .nav-brand .name { font-family: 'Frank Ruhl Libre', serif; font-size: 22px; font-weight: 700; }
  .nav-links { display: flex; align-items: center; gap: 32px; font-size: 15px; font-weight: 600; }
  .nav-links a { color: #B4A692; }
  .nav-links a:hover { color: #F0E7D8; }
  .cart-pill { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: #14100D; padding: 10px 20px; border-radius: 999px; font-weight: 700; cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease; border: none; font-family: 'Assistant', sans-serif; font-size: 15px; }
  .cart-pill:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(226,112,58,0.35); }

  /* ===== HOME ===== */
  .hero { position: relative; padding: 96px 48px 88px; text-align: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background-image: url('/assets/hero.jpeg'); background-size: cover; background-position: center 35%; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,16,13,0.72) 0%, rgba(20,16,13,0.82) 60%, #14100D 100%); }
  .hero-inner { position: relative; max-width: 1280px; margin: 0 auto; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; color: var(--accent); border: 1px solid rgba(226,112,58,0.35); padding: 7px 16px; border-radius: 999px; margin-bottom: 24px; }
  .hero h1 { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 56px; line-height: 1.1; margin: 0 0 18px; }
  .hero h1 em { color: var(--accent); font-style: normal; }
  .hero p { font-size: 18px; line-height: 1.7; color: #B4A692; max-width: 56ch; margin: 0 auto; text-wrap: pretty; }
  .checker { height: 16px; background-image: url('/assets/checker.png'); background-size: auto 220px; background-position: center; opacity: 0.9; }

  .menu-section { max-width: 1280px; margin: 0 auto; padding: 24px 48px 96px; }
  .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 28px; }
  .pizza-card { background: #1D1712; border: 1px solid rgba(240,231,216,0.1); border-radius: 20px; overflow: hidden; cursor: pointer; transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease; animation: ecFadeUp 0.5s ease both; }
  .pizza-card:hover { transform: translateY(-4px); border-color: rgba(226,112,58,0.45); box-shadow: 0 18px 44px rgba(0,0,0,0.4); }
  .pizza-card .img-wrap { position: relative; height: 210px; }
  .pizza-card .img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .img-placeholder { position: absolute; inset: 0; display: grid; place-items: center; background: linear-gradient(145deg, #241D17 0%, #1D1712 60%, #191410 100%); color: #5E5546; font-size: 13.5px; font-weight: 600; gap: 6px; }
  .pizza-card .card-body { padding: 22px 24px 24px; }
  .card-title-row { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .card-title-row .name { font-family: 'Frank Ruhl Libre', serif; font-size: 23px; font-weight: 700; }
  .card-title-row .from-price { font-size: 14px; color: var(--accent); font-weight: 700; white-space: nowrap; }
  .pizza-card .desc { font-size: 14.5px; line-height: 1.6; color: #B4A692; margin: 0 0 18px; min-height: 44px; }
  .card-cta { display: flex; align-items: center; gap: 8px; font-size: 14.5px; font-weight: 700; color: var(--accent); }

  .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 64px; }
  .gallery img { width: 100%; height: 340px; object-fit: cover; border-radius: 16px; }

  /* ===== PRODUCT ===== */
  .product-section { max-width: 1280px; margin: 0 auto; padding: 40px 48px 28px; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #8F8270; margin-bottom: 32px; }
  .breadcrumb a { color: #8F8270; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .current { color: #F0E7D8; font-weight: 600; }
  .product-grid { display: grid; grid-template-columns: minmax(320px, 1fr) minmax(360px, 1.1fr); gap: 56px; align-items: start; }
  @media (max-width: 860px) { .product-grid { grid-template-columns: 1fr; } }
  .product-img-wrap { position: relative; height: clamp(300px, 46vw, 400px); border-radius: 20px; overflow: hidden; }
  .product-img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .product-info { animation: ecFadeUp 0.4s ease both; }
  .product-info h1 { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 46px; margin: 0 0 14px; }
  .product-price { font-family: 'Frank Ruhl Libre', serif; font-size: 34px; color: var(--accent); margin-bottom: 20px; }
  .product-desc { font-size: 16.5px; line-height: 1.75; color: #B4A692; margin: 0 0 30px; max-width: 52ch; text-wrap: pretty; }
  .size-label { font-size: 13px; font-weight: 700; letter-spacing: 0.06em; color: #8F8270; margin-bottom: 12px; }
  .size-row { display: flex; gap: 12px; margin-bottom: 32px; }
  .size-btn { flex: 1; max-width: 200px; background: #1D1712; border: 1px solid rgba(240,231,216,0.12); color: #F0E7D8; border-radius: 14px; padding: 14px; cursor: pointer; font-family: 'Assistant', sans-serif; text-align: center; transition: all 0.16s ease; }
  .size-btn:hover { border-color: rgba(226,112,58,0.5); }
  .size-btn.active { background: rgba(226,112,58,0.12); border-color: var(--accent); }
  .size-btn .size-name { font-size: 16px; font-weight: 700; }
  .size-btn .size-price { font-size: 13.5px; color: #B4A692; margin-top: 2px; }
  .product-features { display: flex; gap: 28px; border-top: 1px solid rgba(240,231,216,0.1); padding-top: 22px; font-size: 14px; color: #8F8270; }
  .product-features > div { display: flex; align-items: center; gap: 8px; }

  /* ===== TOPPINGS BUILDER ===== */
  .builder-section { border-top: 1px solid rgba(240,231,216,0.08); background: linear-gradient(180deg, #181310 0%, #14100D 100%); padding: 56px 32px 88px; margin-top: 24px; }
  .builder-inner { max-width: 1280px; margin: 0 auto; }
  .builder-head { text-align: center; margin-bottom: 34px; }
  .builder-head h2 { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 38px; margin: 0 0 10px; }
  .builder-head p { font-size: 16px; color: #B4A692; margin: 0; }
  .builder-grid { display: grid; grid-template-columns: minmax(280px, 0.95fr) minmax(280px, 1.05fr); gap: 28px; align-items: start; }

  .pizza-visual-col { display: flex; flex-direction: column; align-items: center; gap: 28px; }
  .pizza-visual { position: relative; width: min(360px, 82vw); aspect-ratio: 1; }
  .pv-glow { position: absolute; inset: -40px; border-radius: 50%; background: radial-gradient(circle, rgba(226,112,58,0.12) 0%, transparent 65%); pointer-events: none; }
  .pv-crust { position: absolute; inset: 0; border-radius: 50%; background: radial-gradient(circle at 38% 34%, #E3A968 0%, #C9853E 55%, #A05F24 100%); box-shadow: 0 24px 60px rgba(0,0,0,0.5), inset 0 -6px 18px rgba(0,0,0,0.25); }
  .pv-sauce { position: absolute; inset: 26px; border-radius: 50%; background: radial-gradient(circle at 42% 38%, #C4502E 0%, #A83A20 70%, #8E2E18 100%); }
  .pv-cheese { position: absolute; inset: 34px; border-radius: 50%; background: radial-gradient(circle at 40% 36%, #F2D48A 0%, #E9BE62 50%, #D9A344 100%); box-shadow: inset 0 2px 12px rgba(255,240,190,0.5), inset 0 -8px 20px rgba(160,90,20,0.3); }
  .pv-toppings { position: absolute; inset: 0; pointer-events: none; z-index: 3; }
  .pv-topping { position: absolute; transform: translate(-50%,-50%); animation: ecPop 0.3s ease both; }
  .pv-line-v { position: absolute; left: 50%; top: 26px; bottom: 26px; width: 2px; margin-left: -1px; background: rgba(20,16,13,0.28); z-index: 4; pointer-events: none; }
  .pv-line-h { position: absolute; top: 50%; left: 26px; right: 26px; height: 2px; margin-top: -1px; background: rgba(20,16,13,0.28); z-index: 4; pointer-events: none; }
  .pv-quads { position: absolute; inset: 0; border-radius: 50%; overflow: hidden; z-index: 5; }
  .pv-quad { position: absolute; width: 50%; height: 50%; border: none; cursor: pointer; background: transparent; transition: background 0.18s ease; padding: 0; }
  .pv-quad:hover { background: rgba(240,231,216,0.16) !important; }
  .pv-quad.tl { left: 0; top: 0; border-radius: 100% 0 0 0; }
  .pv-quad.tr { right: 0; top: 0; border-radius: 0 100% 0 0; }
  .pv-quad.bl { left: 0; bottom: 0; border-radius: 0 0 0 100%; }
  .pv-quad.br { right: 0; bottom: 0; border-radius: 0 0 100% 0; }
  .pv-whole-ring { position: absolute; inset: -10px; border-radius: 50%; border: 2px solid var(--accent); box-shadow: 0 0 24px rgba(226,112,58,0.35); pointer-events: none; z-index: 6; }
  .pv-quad-ring { position: absolute; width: 50%; height: 50%; border: 2px solid var(--accent); box-shadow: 0 0 20px rgba(226,112,58,0.3); pointer-events: none; z-index: 6; transition: left 0.2s ease, top 0.2s ease, border-radius 0.2s ease; }
  .pv-target-badge { position: absolute; bottom: -14px; left: 50%; transform: translateX(-50%); background: #241D17; border: 1px solid rgba(240,231,216,0.14); color: #F0E7D8; font-size: 14px; font-weight: 700; padding: 8px 18px; border-radius: 999px; white-space: nowrap; z-index: 7; box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
  .pv-target-badge span { color: var(--accent); }
  .whole-btn { display: inline-flex; align-items: center; gap: 10px; background: transparent; color: #F0E7D8; border: 1px solid rgba(240,231,216,0.25); padding: 12px 26px; border-radius: 999px; font-family: 'Assistant', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.18s ease; margin-top: 8px; }
  .whole-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(226,112,58,0.25); }
  .whole-btn.active { background: var(--accent); color: #14100D; border-color: var(--accent); }

  .toppings-col .toppings-label { font-size: 13px; font-weight: 700; letter-spacing: 0.04em; color: #8F8270; margin-bottom: 16px; }
  .toppings-label .muted { color: #5E5546; }
  .toppings-list { display: grid; grid-template-columns: 1fr; gap: 10px; }
  .topping-btn { display: flex; align-items: center; gap: 14px; width: 100%; text-align: right; background: #1D1712; border: 1px solid rgba(240,231,216,0.1); border-radius: 14px; padding: 12px 16px; cursor: pointer; transition: all 0.16s ease; color: #F0E7D8; font-family: 'Assistant', sans-serif; }
  .topping-btn:hover { border-color: rgba(226,112,58,0.5); transform: translateY(-1px); }
  .topping-btn.active { background: rgba(226,112,58,0.1); border-color: rgba(226,112,58,0.55); }
  .topping-icon { width: 40px; height: 40px; border-radius: 11px; background: #14100D; border: 1px solid rgba(240,231,216,0.1); display: grid; place-items: center; flex-shrink: 0; }
  .topping-text { flex: 1; }
  .topping-text .t-name { font-size: 15.5px; font-weight: 700; }
  .topping-text .t-desc { font-size: 13px; color: #8F8270; margin-top: 1px; }
  .topping-price { font-size: 14px; font-weight: 700; color: var(--accent); white-space: nowrap; flex-shrink: 0; }
  .topping-check { width: 24px; height: 24px; border-radius: 50%; border: 1.5px solid rgba(240,231,216,0.25); background: transparent; display: grid; place-items: center; transition: all 0.16s ease; flex-shrink: 0; }
  .topping-btn.active .topping-check { border-color: var(--accent); background: var(--accent); }
  .topping-check svg { display: none; }
  .topping-btn.active .topping-check svg { display: block; }

  .summary-aside { background: #1D1712; border: 1px solid rgba(240,231,216,0.1); border-radius: 20px; padding: 28px; position: static; grid-column: 1 / -1; box-shadow: 0 20px 50px rgba(0,0,0,0.35); }
  .summary-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
  .summary-head .title { font-family: 'Frank Ruhl Libre', serif; font-size: 22px; font-weight: 700; }
  .summary-head .sub { font-size: 13px; color: #8F8270; font-weight: 700; }
  .summary-rows { display: flex; flex-direction: column; gap: 2px; margin-bottom: 22px; }
  .summary-row { display: flex; align-items: baseline; gap: 12px; padding: 10px 0; border-bottom: 1px solid rgba(240,231,216,0.06); }
  .summary-row .label { font-size: 13px; font-weight: 700; width: 104px; flex-shrink: 0; }
  .summary-row .text { font-size: 14px; line-height: 1.5; }
  .summary-totals { display: flex; flex-direction: column; gap: 8px; padding: 16px 0; border-top: 1px solid rgba(240,231,216,0.1); }
  .summary-line { display: flex; justify-content: space-between; font-size: 14.5px; color: #B4A692; }
  .summary-total { display: flex; justify-content: space-between; align-items: baseline; margin-top: 8px; }
  .summary-total .lbl { font-size: 15.5px; font-weight: 700; }
  .summary-total .val { font-family: 'Frank Ruhl Libre', serif; font-size: 32px; color: var(--accent); }
  .add-cart-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; background: var(--accent); color: #14100D; border: none; border-radius: 14px; padding: 16px; font-family: 'Assistant', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease; margin-top: 6px; }
  .add-cart-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(226,112,58,0.4); }
  .add-cart-btn:active { transform: translateY(0) scale(0.98); }
  .add-cart-btn:disabled { opacity: 0.6; cursor: wait; }
  .summary-note { text-align: center; font-size: 12.5px; color: #5E5546; margin-top: 14px; }

  /* ===== FOOTER ===== */
  .footer { border-top: 1px solid rgba(240,231,216,0.08); padding: 36px 48px; display: flex; justify-content: space-between; align-items: center; max-width: 1280px; margin: 0 auto; font-size: 14px; color: #8F8270; }
  .footer-brand { display: flex; align-items: center; gap: 12px; }
  .footer-brand img { width: 36px; height: 36px; border-radius: 8px; object-fit: cover; }
  .footer-brand .name { font-family: 'Frank Ruhl Libre', serif; font-size: 17px; color: #B4A692; font-weight: 700; }

  .dough-note { font-size: 13.5px; line-height: 1.6; color: #8F8270; margin: 18px 0 0; max-width: 48ch; }

  /* ===== ABOUT ===== */
  .about-section { max-width: 1280px; margin: 0 auto; padding: 72px 48px 96px; }
  .about-kicker { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; color: var(--accent); border: 1px solid rgba(226,112,58,0.35); padding: 7px 16px; border-radius: 999px; margin-bottom: 20px; }
  .about-block { display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px; align-items: center; padding: 48px 0; }
  .about-block + .about-block { border-top: 1px solid rgba(240,231,216,0.08); }
  .about-block h2 { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 40px; line-height: 1.15; margin: 0 0 18px; }
  .about-block h2 em { color: var(--accent); font-style: normal; }
  .about-block p { font-size: 16.5px; line-height: 1.75; color: #B4A692; margin: 0 0 24px; max-width: 56ch; text-wrap: pretty; }
  .about-bullets { display: flex; flex-direction: column; gap: 12px; }
  .about-bullet { display: flex; align-items: center; gap: 12px; font-size: 15px; font-weight: 600; color: #F0E7D8; }
  .about-bullet svg { flex-shrink: 0; }
  .about-features { display: flex; flex-direction: column; gap: 14px; }
  .about-feature { background: #1D1712; border: 1px solid rgba(240,231,216,0.1); border-radius: 16px; padding: 18px 22px; }
  .about-feature .f-title { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  .about-feature .f-desc { font-size: 14px; color: #8F8270; line-height: 1.6; }
  .about-img { width: 100%; height: 340px; object-fit: cover; border-radius: 20px; }
  .about-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin-top: 56px; }
  .about-stat { background: #1D1712; border: 1px solid rgba(240,231,216,0.1); border-radius: 16px; padding: 26px 20px; text-align: center; }
  .about-stat .num { font-family: 'Frank Ruhl Libre', serif; font-size: 40px; color: var(--accent); line-height: 1; }
  .about-stat .lbl { font-size: 14px; color: #B4A692; font-weight: 600; margin-top: 8px; }
  @media (max-width: 900px) {
    .about-section { padding: 48px 20px 72px; }
    .about-block { grid-template-columns: 1fr; gap: 28px; padding: 36px 0; }
    .about-block h2 { font-size: 30px; }
  }

  /* custom basil cursor (basil2.png scaled to 32px) */
  * { cursor: url('/assets/basil-cursor.png') 2 2, auto !important; }

  .toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); background: #241D17; border: 1px solid rgba(226,112,58,0.5); color: #F0E7D8; font-size: 14.5px; font-weight: 600; padding: 12px 24px; border-radius: 999px; z-index: 100; box-shadow: 0 12px 36px rgba(0,0,0,0.5); animation: ecFadeUp 0.25s ease both; }

  @media (max-width: 720px) {
    .nav { padding: 0 20px; }
    .nav-links { gap: 18px; }
    .nav-links a { display: none; }
    .hero { padding: 64px 20px 56px; }
    .hero h1 { font-size: 38px; }
    .menu-section, .product-section { padding-left: 20px; padding-right: 20px; }
    .builder-section { padding: 48px 20px 72px; }
    .builder-grid { grid-template-columns: 1fr; }
    .pizza-visual { width: min(360px, 92vw); }
    .gallery { grid-template-columns: 1fr; }
    .footer { flex-direction: column; gap: 14px; text-align: center; }
  }

  @media (min-width: 1180px) {
    .builder-section { padding-left: 48px; padding-right: 48px; }
    .builder-head { margin-bottom: 48px; }
    .builder-grid { grid-template-columns: minmax(320px, 0.9fr) minmax(320px, 1fr) minmax(320px, 0.95fr); gap: 40px; }
    .pizza-visual { width: min(440px, 32vw); }
    .summary-aside { position: sticky; top: 100px; grid-column: auto; }
  }
</style>
</head>
<body>

<header class="nav">
  <div class="nav-start">
    <div class="nav-brand" data-action="home">
      <img src="/assets/logo.png" alt="Pizza Louise">
      <div class="name">פיצה לואיז</div>
    </div>
    <nav class="nav-links">
      <a href="#/" data-action="home">תפריט</a>
      <a href="#/about" data-action="about">הסיפור שלנו</a>
    </nav>
  </div>
  <button class="cart-pill" id="cart-pill" title="לתשלום">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
    <span id="cart-label">סל · ריק</span>
  </button>
</header>

<main id="app"></main>

<footer class="footer">
  <div class="footer-brand">
    <img src="/assets/logo.png" alt="Pizza Louise">
    <div class="name">פיצה לואיז</div>
  </div>
  <div>כשר חלבי · פתוח א'–ה' 11:00–23:00, מוצ"ש עד חצות</div>
</footer>

<script is:inline type="module" src="/main.js"></script>
</body>
</html>
