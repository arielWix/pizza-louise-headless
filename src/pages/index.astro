---
import Site from '../layouts/Site.astro';

const origin = Astro.url.origin;

const description =
  'פיצה לואיז — פיצה ניו יורקית אמיתית, כשרה חלבית, שנולדה מאהבה לטעמים של מנהטן וברוקלין. בצק ביגה שתופח 72 שעות, רוטב עגבניות ביתי וגבינת מוצרלה פרימיום. משלוח מהיר או איסוף עצמי.';

const check = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Restaurant',
    name: 'פיצה לואיז',
    description,
    servesCuisine: ['פיצה', 'ניו יורק סטייל', 'איטלקי'],
    priceRange: '₪₪',
    url: origin + '/',
    image: origin + '/assets/hero.jpeg',
    acceptsReservations: false,
    hasMenu: origin + '/menu',
    areaServed: 'ראשון לציון',
    openingHours: ['Su-Th 11:00-23:00', 'Sa 20:00-24:00'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'פיצה לואיז — הסיפור שלנו',
    description,
    url: origin + '/',
  },
];
---
<Site
  title="פיצה לואיז — פיצה ניו יורקית אמיתית"
  description={description}
  canonicalPath="/"
  ogImage="/assets/gallery-bar.jpeg"
  jsonLd={jsonLd}
>
  {/* The about story told over the brick-oven image sequence: scrolling both
      scrubs the frames and swaps the text "chapters" laid over the dimmed video. */}
  <section id="oven" class="oven" aria-label="הסיפור של פיצה לואיז">
    <div class="oven-sticky">
      <canvas id="oven-canvas"></canvas>
      <div class="oven-scrim"></div>
      <div class="oven-stage">

        <div class="oven-chapter" data-show="0" data-hide="0.19">
          <h1 class="oven-h1">נולדנו מאהבה לפיצה <em>ניו יורקית</em></h1>
          <p class="oven-lede">הבאנו לישראל את הטעמים האותנטיים של מנהטן וברוקלין — כשר חלבי, טרי כל יום.</p>
        </div>

        <div class="oven-chapter" data-show="0.21" data-hide="0.39">
          <h2 class="oven-h2">הפיצה הטובה ביותר <em>בדרך אליכם!</em></h2>
          <p class="oven-body">אנחנו מבינים שכשרוצים פיצה אמיתית – רוצים אותה מהר! לכן פיתחנו מערכת משלוחים מתקדמת שמבטיחה שהפיצה שלכם תגיע אליכם חמה, טרייה וטעימה בדיוק כמו ברגע שיצאה מהתנור.</p>
          <div class="oven-bullets">
            <div class="oven-bullet"><Fragment set:html={check} /> משלוח עד הבית (ראשל"צ בלבד)</div>
            <div class="oven-bullet"><Fragment set:html={check} /> משלוח תוך 60 דקות</div>
          </div>
        </div>

        <div class="oven-chapter" data-show="0.41" data-hide="0.59">
          <div class="oven-features">
            <div class="oven-feat"><div class="f-title">בצק טרי יום יום</div><div class="f-desc">נילושה בבוקר ומתפחת במשך 24 שעות למרקם מושלם</div></div>
            <div class="oven-feat"><div class="f-title">רוטב עגבניות ביתי</div><div class="f-desc">מבושל לאט עם תבלינים איטלקיים אותנטיים</div></div>
            <div class="oven-feat"><div class="f-title">גבינת מוצרלה פרימיום</div><div class="f-desc">טרייה מדי יום עם המסה מושלמת</div></div>
          </div>
        </div>

        <div class="oven-chapter" data-show="0.61" data-hide="0.79">
          <h2 class="oven-h2">אנחנו מכינים את הפיצה <em>הטובה ביותר בעיר</em></h2>
          <p class="oven-body">פיצה לואיז נוסדה מתוך אהבה אמיתית לפיצה ניו יורקית ורצון להביא לישראל את הטעמים האותנטיים של מנהטן וברוקלין. כל פיצה מוכנת בקפדנות מקסימלית, מהעיסה שנילושה בבוקר ועד לתוספות הטריות שמגיעות מידי יום.</p>
        </div>

        <div class="oven-chapter" data-show="0.81" data-hide="1.01">
          <div class="oven-stats">
            <div class="oven-stat"><div class="num">12</div><div class="lbl">אנשי צוות לשירותכם</div></div>
            <div class="oven-stat"><div class="num">35</div><div class="lbl">הזמנות בשעה</div></div>
            <div class="oven-stat"><div class="num">25</div><div class="lbl">סוגי פיצה</div></div>
            <div class="oven-stat"><div class="num">15,000</div><div class="lbl">לקוחות מרוצים</div></div>
          </div>
        </div>

      </div>
    </div>
  </section>
</Site>

<script>
  import { initOvenSequence } from '../scripts/oven-sequence.js';
  initOvenSequence();
</script>
